// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CARD
  PSE
  NEQUI
  DAVIPLATA
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  VOIDED
}

enum PaymentProvider {
  WOMPI
  EPAYCO
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ExpenseCategory {
  INGREDIENTS
  RENT
  UTILITIES
  STAFF
  EQUIPMENT
  MARKETING
  OTHER
}

enum IngredientUnit {
  KG
  G
  LB
  OZ
  L
  ML
  UNIT
}

enum AlertType {
  LOW_STOCK
  EXPIRING_SOON
  SALES_ANOMALY
  COST_ANOMALY
  STOCK_DEDUCTION_FAILED
}

enum SubscriptionPlan {
  STARTER
  PRO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  OWNER
}

enum OnboardingStep {
  GREETING
  MENU_REVIEW
  RECIPE_LOOP
  STOCK_SETUP
  COMPLETE
}

// ==================== MODELS ====================

model Restaurant {
  id               String           @id @default(uuid())
  slug             String           @unique
  name             String
  phone            String?
  address          String?
  logoUrl          String?
  coverUrl         String?
  paymentProvider  PaymentProvider  @default(WOMPI)
  isActive         Boolean          @default(true)
  isOpen           Boolean          @default(false)
  openHours        Json?            // { monday: { open: "08:00", close: "22:00" }, ... }
  onboardingStatus OnboardingStatus @default(PENDING)
  timezone         String           @default("America/Bogota")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  users                   User[]
  menuCategories          MenuCategory[]
  menuItems               MenuItem[]
  ingredients             Ingredient[]
  stockMovements          StockMovement[]
  orders                  Order[]
  expenses                Expense[]
  aiSummaries             AiSummary[]
  aiAlerts                AiAlert[]
  aiInteractions          AiInteraction[]
  aiOnboardingSession     AiOnboardingSession?
  restaurantPlan          RestaurantPlan?
  restaurantOrderSequence RestaurantOrderSequence?

  @@map("restaurants")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  name             String
  restaurantId     String
  role             UserRole @default(OWNER)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      MenuItem[]

  @@index([restaurantId, position])
  @@map("menu_categories")
}

model MenuItem {
  id             String   @id @default(uuid())
  restaurantId   String
  categoryId     String?
  name           String
  description    String?
  price          Decimal  @db.Decimal(12, 2)
  photoUrl       String?
  photoMediumUrl String?
  photoThumbUrl  String?
  isAvailable    Boolean  @default(true)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipe     Recipe?
  orderItems OrderItem[]

  @@index([restaurantId, categoryId, isAvailable])
  @@index([restaurantId, position])
  @@map("menu_items")
}

model Ingredient {
  id           String         @id @default(uuid())
  restaurantId String
  name         String
  unit         IngredientUnit
  stock        Decimal        @default(0) @db.Decimal(12, 3)
  minStock     Decimal        @default(0) @db.Decimal(12, 3)
  costPerUnit  Decimal        @default(0) @db.Decimal(12, 2)
  expiresAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  recipeItems    RecipeItem[]

  @@index([restaurantId])
  @@map("ingredients")
}

model Recipe {
  id         String   @id @default(uuid())
  menuItemId String   @unique
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  recipeItems RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id           String  @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Decimal @db.Decimal(12, 3)

  // Relations
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_items")
}

model StockMovement {
  id            String            @id @default(uuid())
  ingredientId  String
  restaurantId  String
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  referenceType String?           // 'ORDER' | 'MANUAL' | 'ADJUSTMENT'
  referenceId   String?
  note          String?
  createdAt     DateTime          @default(now())

  // Relations
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([ingredientId, type])
  @@map("stock_movements")
}

model Order {
  id              String      @id @default(uuid())
  restaurantId    String
  orderNumber     Int
  status          OrderStatus @default(PENDING)
  orderType       OrderType   @default(PICKUP)
  total           Decimal     @db.Decimal(12, 2)
  costTotal       Decimal     @default(0) @db.Decimal(12, 2)
  customerName    String
  customerPhone   String
  customerAddress String?
  customerToken   String      @unique @default(uuid())
  notes           String?
  confirmedAt     DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  payment    Payment?

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  menuItemId    String
  menuItemName  String  // snapshot del nombre al momento del pedido
  menuItemPrice Decimal @db.Decimal(12, 2) // snapshot del precio
  menuItemCost  Decimal @default(0) @db.Decimal(12, 2) // snapshot del costo
  quantity      Int
  subtotal      Decimal @db.Decimal(12, 2)

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Payment {
  id         String          @id @default(uuid())
  orderId    String          @unique
  provider   PaymentProvider @default(WOMPI)
  externalId String?         @unique // ID de la transacción en Wompi/ePayco
  status     PaymentStatus   @default(PENDING)
  amount     Decimal         @db.Decimal(12, 2)
  method     PaymentMethod
  paidAt     DateTime?
  rawWebhook Json?           // payload crudo del webhook para auditoría
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Expense {
  id           String          @id @default(uuid())
  restaurantId String
  amount       Decimal         @db.Decimal(12, 2)
  category     ExpenseCategory @default(OTHER)
  description  String
  rawInput     String?         // texto original del dueño
  date         DateTime        @db.Date
  receiptUrl   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, date])
  @@map("expenses")
}

model AiSummary {
  id           String   @id @default(uuid())
  restaurantId String
  date         DateTime @db.Date
  content      Json     // NightlySummary struct
  generatedAt  DateTime @default(now())

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date])
  @@map("ai_summaries")
}

model AiAlert {
  id            String    @id @default(uuid())
  restaurantId  String
  type          AlertType
  message       String
  isRead        Boolean   @default(false)
  relatedEntity String?   // JSON con referencia al objeto relacionado
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, isRead])
  @@map("ai_alerts")
}

model AiInteraction {
  id           String   @id @default(uuid())
  restaurantId String
  model        String   // 'haiku' | 'sonnet'
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(8, 6)
  taskType     String   // 'classify_expense' | 'parse_stock' | 'copilot' | 'nightly_summary' | 'onboarding'
  createdAt    DateTime @default(now())

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@map("ai_interactions")
}

model AiOnboardingSession {
  id           String         @id @default(uuid())
  restaurantId String         @unique
  messages     Json           @default("[]") // AIMessage[]
  currentStep  OnboardingStep @default(GREETING)
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("ai_onboarding_sessions")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model RestaurantPlan {
  id               String             @id @default(uuid())
  restaurantId     String             @unique
  plan             SubscriptionPlan   @default(PRO)
  status           SubscriptionStatus @default(TRIAL)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_plans")
}

// Tabla auxiliar para orderNumber auto-incremental por restaurante (atómico)
model RestaurantOrderSequence {
  restaurantId    String @id
  lastOrderNumber Int    @default(0)

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_order_sequences")
}
